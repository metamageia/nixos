      "title": "Budget vs Actual (This Month)",
      "type": "bargauge",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "homestead-pg" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT c.name AS category, COALESCE(SUM(ABS(t.amount)), 0) AS spent, b.amount AS budget FROM budgets b JOIN categories c ON b.category_id = c.id LEFT JOIN transactions t ON t.category_id = c.id AND t.amount < 0 AND t.date >= date_trunc('month', CURRENT_DATE) AND t.date < date_trunc('month', CURRENT_DATE) + INTERVAL '1 month' WHERE b.month = date_trunc('month', CURRENT_DATE) GROUP BY c.name, b.amount ORDER BY c.name",
          "refId": "A"
        }
      ]
