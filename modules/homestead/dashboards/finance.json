          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COALESCE(SUM(lb.balance), 0) AS \"Total Balance\" FROM (SELECT DISTINCT ON (account_id) account_id, balance FROM balance_snapshots ORDER BY account_id, snapshot_date DESC, CASE source WHEN 'manual' THEN 0 ELSE 1 END, id DESC) lb",
          "refId": "A"
