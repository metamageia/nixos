          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT snapshot_date AS time, SUM(balance) AS \"Net Worth\" FROM (SELECT DISTINCT ON (account_id, snapshot_date) account_id, snapshot_date, balance FROM balance_snapshots ORDER BY account_id, snapshot_date, CASE source WHEN 'manual' THEN 0 ELSE 1 END, id DESC) best GROUP BY snapshot_date ORDER BY snapshot_date",
          "refId": "A"
