      "title": "Income vs Expenses by Month",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "homestead-pg" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT date_trunc('month', date) AS time, SUM(CASE WHEN amount > 0 THEN amount ELSE 0 END) AS \"Income\", SUM(CASE WHEN amount < 0 THEN ABS(amount) ELSE 0 END) AS \"Expenses\" FROM transactions GROUP BY date_trunc('month', date) ORDER BY time",
          "refId": "A"
        }
      ]
    },
