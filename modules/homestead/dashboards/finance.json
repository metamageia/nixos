      "title": "Spending by Category",
      "type": "piechart",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "homestead-pg" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COALESCE(c.name, 'uncategorized') AS metric, SUM(ABS(t.amount)) AS \"value\" FROM transactions t LEFT JOIN categories c ON t.category_id = c.id WHERE t.amount < 0 AND t.date >= date_trunc('month', CURRENT_DATE) GROUP BY c.name ORDER BY \"value\" DESC",
          "refId": "A"
        }
      ]
    },
